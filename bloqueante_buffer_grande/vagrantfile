Vagrant.configure("2") do |config|
  2.times do |num|
    config.vm.define ("vm%01d" % (num + 1)) do |machine|
      machine.vm.box = "ubuntu/jammy64"

      # give both VMs a host-only/private network on 192.168.50.0/24
      if (num + 1 == 1)
        # vm1 (server)
        machine.vm.network "private_network", ip: "192.168.50.10"
      else
        # vm2 (client) - also keep optional bridged interface if needed
        machine.vm.network "private_network", ip: "192.168.50.11"
        machine.vm.network "public_network", bridge: "wlp0s20f3", use_dhcp_assigned_default_route: true
      end

      machine.vm.hostname = "vm#{num + 1}"

      machine.vm.synced_folder ".", "/vagrant_shared"

      machine.vm.provider "virtualbox" do |vb|
        vb.memory = "512"
      end

      machine.vm.provision "shell", inline: <<-SHELL
        apt-get update
        apt-get upgrade -y
        apt-get install -y build-essential net-tools zip joe default-jdk
      SHELL
    end
  end
end